# Description: 生产环境配置文件 变量名必须以VITE_开头
ENV='production'

# 后端服务端口
VITE_SERVER_PORT=8080

# 前端服务端口
VITE_CLIENT_PORT=443

# 后端接口地址
VITE_BASE_API = /api

# 文件上传接口地址
VITE_FILE_API = /api

# 修改为的线上地址
VITE_BASE_URL = https://dev.jiaopengzi.com

# 最大硬件并发数
VITE_MAX_NAVIGATOR_HARDWARE_CONCURRENCY = 9

# 版本信息
VITE_GIT_TAG='v0.4.6'
VITE_GIT_COMMIT='a71a1dd3c62f9e8df42ef29b4a84c1a977ac646e'
VITE_BUILD_TIME='2026-03-02 09:16:02 +08:00'
