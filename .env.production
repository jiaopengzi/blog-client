# Description: 生产环境配置文件 变量名必须以VITE_开头
ENV='production'

# 后端服务端口
VITE_SERVER_PORT=8080

# 前端服务端口
VITE_CLIENT_PORT=443

# 后端接口地址
VITE_BASE_API = /api

# 文件上传接口地址
VITE_FILE_API = /api

# 修改为的线上地址
VITE_BASE_URL = https://dev.jiaopengzi.com

# 最大硬件并发数
VITE_MAX_NAVIGATOR_HARDWARE_CONCURRENCY = 9

# 版本信息
VITE_GIT_TAG='0.1.2-beta'
VITE_GIT_COMMIT='906ed7765c3276909d9b10deeb40d97d4d6bd927'
VITE_BUILD_TIME='2025-11-19 10:38:54 +08:00'
