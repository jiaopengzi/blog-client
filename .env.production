# Description: 生产环境配置文件 变量名必须以VITE_开头
ENV='production'

# 后端服务端口
VITE_SERVER_PORT=8080

# 前端服务端口
VITE_CLIENT_PORT=443

# 后端接口地址
VITE_BASE_API = /api

# 文件上传接口地址
VITE_FILE_API = /api

# 修改为的线上地址
VITE_BASE_URL = https://dev.jiaopengzi.com

# 最大硬件并发数
VITE_MAX_NAVIGATOR_HARDWARE_CONCURRENCY = 9

# 版本信息
VITE_GIT_TAG='0.4.2'
VITE_GIT_COMMIT='5c17441d6dfe43d36a581a2873e4444145fc87b1'
VITE_BUILD_TIME='2026-01-04 16:37:21 +08:00'
