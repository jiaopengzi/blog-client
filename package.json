{
    "name": "blog-client",
    "description": "一个博客系统前端项目",
    "author": "焦棚子 <jiaopengzi@outlook.com>",
    "license": "MIT",
    "homepage": "https://jiaopengzi.com",
    "repository": {
        "type": "git",
        "url": "https://github.com/jiaopengzi/blog-client"
    },
    "files": [
        "dist",
        "README.md"
    ],
    "keywords": [
        "blog-client",
        "vue3 blog-client"
    ],
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "node ./scripts/set-env-version.js && node ./scripts/open-document.js && vite",
        "build": "run-p type-check build-only",
        "preview": "node ./scripts/open-document.js && vite preview",
        "build-only": "node ./scripts/set-env-version.js && vite build && node ./scripts/dns-prefetch.js",
        "type-check": "vue-tsc --noEmit -p tsconfig.app.json --composite false",
        "lint": "oxlint",
        "lint:fix": "oxlint --fix",
        "format": "prettier --write src/",
        "testOnline": "vitest",
        "test": "vitest run",
        "gen:mdlint-rules": "node ./scripts/generate-mdlint-rules.js"
    },
    "dependencies": {
        "@codemirror/autocomplete": "6.20.1",
        "@codemirror/commands": "6.10.3",
        "@codemirror/lang-css": "6.3.1",
        "@codemirror/lang-html": "6.4.11",
        "@codemirror/lang-javascript": "6.2.5",
        "@codemirror/lang-json": "6.0.2",
        "@codemirror/lang-markdown": "6.5.0",
        "@codemirror/language": "6.12.3",
        "@codemirror/lint": "6.9.5",
        "@codemirror/search": "6.7.0",
        "@codemirror/state": "6.6.0",
        "@codemirror/theme-one-dark": "6.1.3",
