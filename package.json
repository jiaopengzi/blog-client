    "element-plus": "^2.7.7",
    "emoji.json": "^15.1.0",
    "highlight.js": "^11.10.0",
    "html2canvas": "^1.4.1",
    "katex": "^0.16.11",
    "marked": "^13.0.2",
    "marked-alert": "^2.0.1",
    "marked-code-format": "^1.1.5",
    "marked-custom-heading-id": "^2.0.8",
    "marked-emoji": "^1.4.1",
    "marked-extended-tables": "^1.0.8",
    "marked-footnote": "^1.2.2",
    "marked-highlight": "^2.1.3",
    "marked-katex-extension": "^5.0.2",
    "marked-mangle": "^1.1.8",
    "marked-xhtml": "^1.0.10",
    "pinia": "^2.1.7",
    "reset-css": "^5.0.2",
    "vue": "^3.4.32",
    "vue-cropper": "^1.1.4",
    "vue-cropperjs": "^5.0.0",
    "vue3-emoji-picker": "^1.1.8",
