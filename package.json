        "screenfull": "6.0.2",
        "throttle-debounce": "5.0.2",
        "vue": "3.5.33",
        "vue-cropper": "0.6.5",
        "vue-cropperjs": "5.0.0",
        "vue-draggable-plus": "0.6.1",
        "vue-router": "5.0.6",
        "vue3-emoji-picker": "1.1.8",
        "vue3-slide-verify": "1.1.8"
    },
    "devDependencies": {
        "@babel/core": "7.29.0",
        "@babel/preset-env": "7.29.2",
        "@babel/preset-typescript": "7.28.5",
        "@tsconfig/node24": "24.0.4",
        "@types/crypto-js": "4.2.2",
