        "axios": "^1.13.5",
        "glob": "^13.0.2",
        "jsdom": "^28.0.0",
        "node-html-parser": "^7.0.2",
        "npm-run-all": "^4.1.5",
        "oxlint": "^1.46.0",
        "prettier": "^3.8.1",
        "sass": "^1.97.3",
        "ts-node": "^10.9.2",
        "typescript": "^5.9.3",
        "unplugin-auto-import": "^21.0.0",
        "unplugin-vue-components": "^31.0.0",
