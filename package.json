{
    "name": "blog-client",
    "version": "0.0.2",
    "description": "一个博客系统前端项目",
    "author": "焦棚子 <jiaopengzi@outlook.com>",
    "license": "MIT",
    "homepage": "https://jiaopengzi.com",
    "repository": {
        "type": "git",
        "url": "https://gitee.com/jiaopengzi/blog-client"
    },
    "files": [
        "dist",
        "README.md"
    ],
    "keywords": [
        "blog-client",
        "vue3 blog-client"
    ],
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "node ./scripts/openDocument.js && vite --host 0.0.0.0",
        "build": "run-p type-check build-only",
        "preview": "vite preview",
        "build-only": "vite build && node ./scripts/dns-prefetch.js",
        "type-check": "vue-tsc --noEmit -p tsconfig.app.json --composite false",
        "lint": "eslint . --ext .vue,.js,.jsx,.ts,.tsx --fix --ignore-path .eslintignore",
        "format": "prettier --write src/",
        "testOnline": "vitest",
        "test": "vitest run"
    },
