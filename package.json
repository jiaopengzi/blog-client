    "@types/crypto-js": "^4.2.2",
    "@types/katex": "^0.16.7",
    "@types/node": "^20.14.11",
    "@types/rollup": "^0.54.0",
    "@types/tinycolor2": "^1.4.6",
    "@vitejs/plugin-vue": "^4.6.2",
    "@vitejs/plugin-vue-jsx": "^3.1.0",
    "@vue/eslint-config-prettier": "^7.1.0",
    "@vue/eslint-config-typescript": "^11.0.3",
    "@vue/tsconfig": "^0.4.0",
    "axios": "^1.7.2",
    "eslint": "^8.57.0",
    "eslint-plugin-vue": "^9.27.0",
