        "@vue/tsconfig": "0.9.1",
        "axios": "1.15.2",
        "eslint": "10.2.1",
        "eslint-plugin-vue": "10.9.0",
        "glob": "13.0.6",
        "jsdom": "29.0.2",
        "node-html-parser": "7.1.0",
        "npm-run-all": "4.1.5",
        "oxlint": "1.61.0",
        "prettier": "3.8.3",
        "rolldown": "1.0.0-rc.17",
        "sass": "1.99.0",
        "ts-node": "10.9.2",
        "typescript": "6.0.3",
        "unplugin-auto-import": "21.0.0",
