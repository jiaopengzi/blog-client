        "@lezer/highlight": "1.2.3",
        "@replit/codemirror-vim": "6.3.0",
        "@uiw/codemirror-themes": "4.25.9",
        "@unhead/vue": "3.0.5",
        "@vueuse/core": "14.2.1",
        "@zumer/snapdom": "2.9.0",
        "cropperjs": "2.1.1",
        "crypto-js": "4.2.0",
        "dompurify": "3.4.1",
        "element-plus": "2.13.7",
        "emoji.json": "16.0.0",
        "highlight.js": "11.11.1",
        "hls.js": "1.6.16",
        "katex": "0.16.45",
        "marked": "18.0.2",
        "marked-alert": "2.1.2",
        "marked-code-format": "1.1.6",
        "marked-custom-heading-id": "2.0.17",
        "marked-emoji": "2.0.3",
        "marked-footnote": "1.4.0",
        "marked-highlight": "2.2.4",
        "marked-katex-extension": "5.1.8",
        "marked-mangle": "1.1.13",
        "marked-xhtml": "1.0.15",
