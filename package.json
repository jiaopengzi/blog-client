    "@vue/eslint-config-prettier": "^7.1.0",
    "@vue/eslint-config-typescript": "^11.0.3",
    "@vue/tsconfig": "^0.4.0",
    "axios": "^1.6.2",
    "eslint": "^8.54.0",
    "eslint-plugin-vue": "^9.19.2",
    "glob": "^10.3.10",
    "node-html-parser": "^6.1.11",
    "npm-run-all": "^4.1.5",
    "sass": "^1.69.5",
    "unplugin-auto-import": "^0.16.7",
    "unplugin-vue-components": "^0.25.2",
