    "@codemirror/language": "^6.10.0",
    "@codemirror/lint": "^6.4.2",
    "@codemirror/search": "^6.5.5",
    "@codemirror/state": "^6.4.0",
    "@codemirror/theme-one-dark": "^6.1.2",
    "@codemirror/view": "^6.23.0",
    "@element-plus/icons-vue": "^2.3.1",
    "@unhead/vue": "^1.8.9",
    "@vueuse/core": "^10.7.1",
    "clipboard": "^2.0.11",
    "codemirror": "^6.0.1",
