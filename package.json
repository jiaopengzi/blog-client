{
  "name": "blog-client",
  "version": "0.0.1",
  "description": "一个博客系统前端项目",
  "author": "焦棚子 <jiaopengzi@outlook.com>",
  "license": "MIT",
  "homepage": "https://jiaopegnzi.com",
  "repository": {
    "type": "git",
    "url": "https://gitee.com/jiaopengzi/blog-client"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "blog-client",
    "vue3 blog-client"
  ],
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "run-p type-check build-only build-dns",
    "preview": "vite preview",
    "build-only": "vite build && node ./scripts/dns-prefetch.js",
    "build-dns": "node ./scripts/dns-prefetch.js",
    "type-check": "vue-tsc --noEmit -p tsconfig.app.json --composite false",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix --ignore-path .gitignore",
    "format": "prettier --write src/"
  },
  "dependencies": {
