        "@vueuse/core": "^14.2.1",
        "@zumer/snapdom": "^2.1.0",
        "cropperjs": "^2.1.0",
        "crypto-js": "^4.2.0",
        "dompurify": "^3.3.1",
        "element-plus": "^2.13.2",
        "emoji.json": "^16.0.0",
        "highlight.js": "^11.11.1",
        "hls.js": "^1.6.15",
