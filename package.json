    "element-plus": "^2.4.4",
    "emoji.json": "^15.1.0",
    "highlight.js": "^11.9.0",
    "html2canvas": "^1.4.1",
    "katex": "^0.16.9",
    "marked": "^11.1.1",
    "marked-alert": "^2.0.1",
    "marked-code-format": "^1.1.3",
    "marked-custom-heading-id": "^2.0.6",
    "marked-emoji": "^1.3.1",
    "marked-footnote": "^1.2.2",
    "marked-highlight": "^2.1.0",
    "marked-katex-extension": "^5.0.0",
    "marked-mangle": "^1.1.6",
    "marked-xhtml": "^1.0.8",
    "pinia": "^2.1.7",
    "reset-css": "^5.0.2",
    "vue": "^3.4.3",
    "vue-cropper": "^1.1.1",
    "vue-cropperjs": "^5.0.0",
