    "@codemirror/lint": "^6.4.2",
    "@codemirror/search": "^6.5.5",
    "@codemirror/state": "^6.3.2",
    "@codemirror/theme-one-dark": "^6.1.2",
    "@codemirror/view": "^6.22.1",
    "@element-plus/icons-vue": "^2.3.1",
    "@unhead/vue": "^1.8.8",
    "@vueuse/core": "^10.7.0",
    "clipboard": "^2.0.11",
    "codemirror": "^6.0.1",
    "cropperjs": "^1.6.1",
    "element-plus": "^2.4.3",
    "highlight.js": "^11.9.0",
    "marked": "^11.0.1",
    "marked-code-format": "^1.1.2",
    "marked-custom-heading-id": "^2.0.6",
    "marked-emoji": "^1.3.1",
    "marked-footnote": "^1.2.1",
    "marked-highlight": "^2.0.9",
    "marked-katex-extension": "^4.0.5",
    "marked-mangle": "^1.1.6",
    "marked-xhtml": "^1.0.8",
    "moment-timezone": "^0.5.43",
    "pinia": "^2.1.7",
    "reset-css": "^5.0.2",
    "typescript": "^5.3.2",
    "vue": "^3.3.11",
    "vue-codemirror": "^6.1.1",
    "vue-cropper": "^1.1.1",
    "vue-cropperjs": "^5.0.0",
    "vue3-slide-verify": "^1.1.4"
