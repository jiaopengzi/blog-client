{
  "extends": "./tsconfig.app.json",
  "include": [
    "env.d.ts",
    "auto-imports.d.ts",
    "components.d.ts",
    "types/**/*.d.ts",
    "src/**/*.ts"
  ],
  "exclude": [
    "dist",
    "node_modules",
    "coverage"
  ],
  "compilerOptions": {
    "composite": true,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.vitest.tsbuildinfo",
    "lib": [
      "ES2025",
      "DOM",
      "DOM.Iterable"
    ],
    "types": [
      "node",
      "jsdom"
    ]
  }
}