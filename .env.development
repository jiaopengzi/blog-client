# Description: 开发环境配置文件 变量名必须以VITE_开头
ENV='development'

# 后端服务端口
VITE_SERVER_PORT=8080

# 前端服务端口
VITE_CLIENT_PORT=8081

# 后端接口地址
VITE_BASE_API = /api

# 文件上传接口地址
VITE_FILE_API = /api

# 前端地址
VITE_BASE_URL = http://localhost:7364

# 最大硬件并发数
VITE_MAX_NAVIGATOR_HARDWARE_CONCURRENCY = 10

# 版本信息
VITE_GIT_TAG='0.2.0'
VITE_GIT_COMMIT='7327511ef8740d99c0c39760601bf369aba1e31e'
VITE_BUILD_TIME='2025-12-06 15:03:31 +08:00'
